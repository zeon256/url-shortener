# Compose defaults. Copy to .env to customize `docker compose up`.

# Web app
WEB_PORT=8080
VITE_BACKEND_URL=http://localhost:8000

# API
API_PORT=8000
API_PUBLIC_HOST=localhost:8000

# Postgres
POSTGRES_PORT=5432
POSTGRES_USER=urlshort
POSTGRES_PASSWORD=urlshort
POSTGRES_DB=urlshort
POSTGRES_POOL_SIZE=5
POSTGRES_ACQUIRE_TIMEOUT=30
